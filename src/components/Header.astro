---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

// astro.config.mjs の base 設定を内部リンクに反映するためのプレフィックス
// BASE_URL は環境により末尾スラッシュの有無が変わるため、無し側に正規化してから '/' を付け直す
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={`${base}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`}>Home</HeaderLink>
			<HeaderLink href={`${base}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${base}/about`}>About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.youtube.com/SaMeManami" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Visit Syota Sasaki's YouTube channel</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31 31 0 0 1 0 7.68v-.123c.002-.215.01-.958.064-1.778l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A100 100 0 0 1 7.858 2zM6.4 5.209v4.818l4.157-2.408z"
					></path></svg
				>
			</a>
			<a href="https://speakerdeck.com/syotasasaki593876" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Visit Syota Sasaki's Speaker Deck</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M10.25 14.4375v-4.875h3.96875c.67708 0 1.22396.21354 1.64062.64062.41667.42709.625.94793.625 1.5625v.59375c0 .60417-.20833 1.11459-.625 1.53125-.41666.41667-.96354.625-1.64062.625H10.25zM7.0625 18h6.96875c1.30209 0 2.41667-.45833 3.34375-1.375S18.75 14.59375 18.75 13.28125v-.59375c0-1.32292-.46354-2.46354-1.39063-3.42188-.92708-.95833-2.04167-1.4375-3.34375-1.4375H10.25V6h-3.1875V18z"
					></path></svg
				>
			</a>
			<a href="https://github.com/s-sasaki-earthsea-wizard" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Go to Syota Sasaki's GitHub profile</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
